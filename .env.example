# Copy to .env and fill in real values. Never commit .env.

DJANGO_SECRET_KEY=change-me-generate-a-real-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,django,garmin.haresign.dev

POSTGRES_DB=garmin
